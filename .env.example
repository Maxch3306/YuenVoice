# Server
NODE_ENV=development
PORT=3001
API_PREFIX=/api

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/yuenvoice

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=your-access-secret-min-32-chars-here
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars-here

# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@yuenvoice.app

# File Upload
UPLOAD_PROVIDER=local
UPLOAD_DIR=./uploads
UPLOAD_MAX_SIZE=10485760

# S3 (optional, if UPLOAD_PROVIDER=s3)
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Admin Seed Account (used by seed script on first run)
ADMIN_EMAIL=admin@yuenvoice.app
ADMIN_PASSWORD=admin123
ADMIN_NAME=System Admin
